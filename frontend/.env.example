# Server-side base URL the BFF (route handlers / DAL / Server Actions) uses to
# reach FastAPI. Never exposed to the browser - the browser only ever talks to
# this Next.js server (same-origin BFF pattern), never to FastAPI directly.
BACKEND_URL=http://localhost:8000

# Symmetric key used to sign/verify the BFF's own encrypted session cookie
# (holds the FastAPI access + refresh tokens server-side). Generate one with:
#   openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-hex-string
